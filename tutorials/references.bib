@article{mollerfrozen,
doi = {10.1088/1367-2630/14/2/023051},
year = {2012},
month = {feb},
publisher = {IOP Publishing},
volume = {14},
number = {2},
pages = {023051},
author = {Möller, Marco and Drossel, Barbara},
title = {The formation of the frozen core in critical {B}oolean networks},
journal = {New Journal of Physics},
abstract = {We investigate numerically and analytically the formation of the frozen core in critical random Boolean networks with biased functions. We demonstrate that a previously used efficient algorithm for obtaining the frozen core, which starts from the nodes with constant functions, fails when the number of inputs per node k exceeds 4. We present computer simulation data for the process of formation of the frozen core and its robustness and show that several important features of the data can be derived using a mean-field calculation. Our results show that the dynamics of the formation of the frozen core for k &gt; 4 are very similar to those for the case of k ⩽ 4. As in the case of k ⩽ 4, most nodes also always become frozen on the same value for k &gt; 4, with the possible exception of very special configurations that are not visible in either computer simulations that start from random initial states or in mean-field theory, which evaluates what happens typically.}
}

